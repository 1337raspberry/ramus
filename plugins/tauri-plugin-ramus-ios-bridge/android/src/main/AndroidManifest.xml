<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <!-- Android 13+ runtime permission for the lock-screen / notification
         widget. Audio still plays without it; the controls just won't
         render. We request it at first `mpvInit`. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Read-only access to the active network's transport type so the
         player can flip into transcode mode automatically when the user
         drops onto cellular. Non-runtime, no prompt. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application>
        <service
            android:name="com.ramus.iosbridge.MpvForegroundService"
            android:foregroundServiceType="mediaPlayback"
            android:exported="true">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
            </intent-filter>
        </service>
    </application>
</manifest>
