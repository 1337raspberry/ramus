<?xml version="1.0" encoding="utf-8"?>
<!--
  Plex servers on a home network are almost always reached over plain HTTP
  on the LAN (e.g. http://192.168.1.100:32400). Android's default release
  cleartext block (usesCleartextTraffic="false") silently kills every such
  connection, leaving the release APK unable to talk to a self-hosted Plex
  for the majority of users.

  Permitting cleartext globally is the pragmatic choice for a Plex client:
  HTTPS servers (e.g. *.plex.direct, plex.tv) still get their certificates
  validated normally; only the cleartext-prohibition fuse is removed.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
