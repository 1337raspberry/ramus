{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/nicegui/static/tauri-conf-schema.json",
  "productName": "ramus",
  "version": "1.0.0",
  "identifier": "com.ramus.app",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": {
      "cwd": "../ui",
      "script": "npm run dev"
    },
    "beforeBuildCommand": {
      "cwd": "../ui",
      "script": "npm run build"
    }
  },
  "app": {
    "windows": [
      {
        "title": "ramus",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$APPDATA/**",
            "$HOME/Library/Application Support/com.raspsoft.ramus/**",
            "$HOME/.local/share/ramus/**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
