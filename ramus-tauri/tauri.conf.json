{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ramus",
  "identifier": "com.ramus.app",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": {
      "cwd": "../ui",
      "script": "pnpm run dev"
    },
    "beforeBuildCommand": {
      "cwd": "../ui",
      "script": "pnpm run build"
    }
  },
  "app": {
    "windows": [
      {
        "title": "ramus",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$APPDATA/**",
            "$HOME/Library/Application Support/com.raspsoft.ramus/**",
            "$HOME/.local/share/ramus/**",
            "$HOME/AppData/Roaming/raspsoft/ramus/**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "1337raspberry",
    "homepage": "https://github.com/1337raspberry/ramus",
    "shortDescription": "genre-first Plex music player",
    "longDescription": "ramus is a genre-first music client for Plex focused on discovering and exploring your existing library. Out of the box It's designed to function with the metadata plex has already assigned your albums to give you a rich hierarchical tree-like view of your library, while genre-obsessives can go as deep and custom as they wish and browse by their own dream musical taxonomy.",
    "license": "MIT",
    "licenseFile": "../licenses/LICENSE",
    "category": "Music",
    "resources": [
      "../licenses/LICENSE",
      "../licenses/LICENSE.LGPL-2.1",
      "../licenses/LICENSE.MPL-2.0",
      "../licenses/NOTICE.md",
      "../licenses/THIRD_PARTY_LICENSES.md"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "depends": ["libmpv2 | libmpv1", "libwebkit2gtk-4.1-0", "libgtk-3-0"],
        "files": {
          "/usr/share/metainfo/com.ramus.app.metainfo.xml": "metainfo/com.ramus.app.metainfo.xml"
        }
      },
      "rpm": {
        "depends": ["mpv-libs", "webkit2gtk4.1", "gtk3"],
        "files": {
          "/usr/share/metainfo/com.ramus.app.metainfo.xml": "metainfo/com.ramus.app.metainfo.xml"
        }
      }
    },
    "macOS": {
      "dmg": {
        "background": "dmg/background.png",
        "windowSize": { "width": 600, "height": 600 },
        "appPosition": { "x": 150, "y": 253 },
        "applicationFolderPosition": { "x": 450, "y": 253 }
      }
    }
  }
}
