# Supply-chain hardening.
#
# ignore-scripts=true: Skip lifecycle scripts (preinstall/install/postinstall)
# for every dependency. Most npm supply-chain attacks (Shai-Hulud family etc.)
# deliver their payload via a postinstall hook in a poisoned package version;
# this neuters that vector even if a bad version makes it into node_modules.
# This is a hard kill switch that overrides pnpm's `onlyBuiltDependencies`
# allowlist — NO install scripts run, allowlisted or not. The only known
# affected package in this tree is `fsevents` (optional, macOS file watching);
# vite falls back to node's fs.watch and HMR still works. If a future dep
# genuinely needs its postinstall (e.g. native binary download), the choice
# is either `pnpm rebuild <pkg>` once after install, or relax this to
# `ignore-scripts=false` + an explicit `pnpm.onlyBuiltDependencies` allowlist
# in package.json. Don't relax silently.
ignore-scripts=true

# minimum-release-age=2880: Refuse to install any package version published
# less than 48 hours ago. Buys time for the security community (Socket, Snyk,
# RustSec-equivalent, etc.) to detect and yank a compromised release before
# it lands in our lockfile. pnpm-only — npm ignores this key.
minimum-release-age=2880

# engine-strict=true: Fail install when a dependency's `engines.node` range
# excludes the local Node version, instead of warning. Keeps the lockfile
# honest about what actually runs.
engine-strict=true
