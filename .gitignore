.DS_Store
.build/
swift-project/RamusMusicCore/.build/
swift-project/RamusMusicCore/.swiftpm/
target/
ui/node_modules/
ui/dist/
dev/
.playwright-mcp/
# libmpv-2.dll downloaded by the Release workflow on Windows runners —
# not a checked-in binary; CI fetches it fresh each build.
ramus-tauri/windows-deps/

# libmpv + transitive dylibs bundled by scripts/bundle-macos-libmpv.py
# during the Release workflow on macOS runners. Generated fresh each
# build from brew's libmpv install — never commit these.
ramus-tauri/macos-frameworks/
ramus-tauri/tauri.macos.conf.json

# libmpv + transitive .so files bundled by scripts/bundle-linux-libmpv.py
# during the Release workflow on Linux runners. Generated fresh each
# build from apt's libmpv2 install — never commit these.
ramus-tauri/linux-libs/
ramus-tauri/tauri.linux.conf.json

# Personal code-review scratch notes (area*-pass*.md, review-pass*.md)
*-pass*.md

# Keep CLAUDE.md local only — not tracked in the repo
CLAUDE.md

# Personal TODO scratch pad — CI-verification steps to run once GH
# Actions minutes return. Not meaningful to other contributors.
CI-check-to-do.md

# Drafted GitHub-issue bodies to file once the repo goes public.
# Local scratch only — not part of the project.
LAUNCH-ISSUES.md

# Android release signing — keystore + credentials never committed
*.keystore
*.jks
signing.properties

# Environment + local override files (Vite reads .env.local etc. at runtime)
.env
.env.*
*.local

# Genre AKA source + merge script — local-only authoring tools.
# open.json (the merged output) IS committed.
ramus-tauri/data/aka.txt
scripts/merge-aka-into-open-json.py

# Genre tree editor — Playwright screenshots are local-only.
# The tool source under tools/genre-editor/ stays trackable.
tools/genre-editor/screenshots/

# Tauri ACL manifests + per-platform capability schemas. Auto-generated
# by `tauri-build` from each plugin's permission list at compile time;
# the contents flip every time you switch between desktop and mobile
# builds (window-state plugin is desktop-only, etc.), so committing
# them just means a perpetually dirty working tree. Hand-written
# capability files under `ramus-tauri/capabilities/` ARE tracked.
ramus-tauri/gen/schemas/
