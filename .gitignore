.DS_Store
.build/
swift-project/RamusMusicCore/.build/
swift-project/RamusMusicCore/.swiftpm/
target/
ui/node_modules/
ui/dist/
dev/
# libmpv-2.dll downloaded by the Release workflow on Windows runners —
# not a checked-in binary; CI fetches it fresh each build.
ramus-tauri/windows-deps/

# libmpv + transitive dylibs bundled by scripts/bundle-macos-libmpv.py
# during the Release workflow on macOS runners. Generated fresh each
# build from brew's libmpv install — never commit these.
ramus-tauri/macos-frameworks/
ramus-tauri/tauri.macos.conf.json

# libmpv + transitive .so files bundled by scripts/bundle-linux-libmpv.py
# during the Release workflow on Linux runners. Generated fresh each
# build from apt's libmpv2 install — never commit these.
ramus-tauri/linux-libs/
ramus-tauri/tauri.linux.conf.json

# Personal code-review scratch notes (area*-pass*.md, review-pass*.md)
*-pass*.md

# Keep CLAUDE.md local only — not tracked in the repo
CLAUDE.md

# Personal TODO scratch pad — CI-verification steps to run once GH
# Actions minutes return. Not meaningful to other contributors.
CI-check-to-do.md

# Android release signing — keystore + credentials never committed
*.keystore
*.jks
signing.properties